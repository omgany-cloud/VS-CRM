# Copy this file to .env and fill in real values before deploying.
# .env is gitignored — never commit real secrets.

# Port the server listens on. Defaults to 4000 if unset.
PORT=4000

# Signs every JWT (internal user sessions + portal sessions). If unset,
# the server auto-generates and persists a random one at
# server/data/.jwt_secret on first run — fine for local use, but for a
# real deployment set this explicitly (e.g. from a secret manager) so
# the secret doesn't live on the same disk as the database it protects.
JWT_SECRET=

# Only needed once you have a real domain and a TLS certificate (e.g.
# via Let's Encrypt). If both are set, the server listens over HTTPS
# using these files instead of plain HTTP. See DEPLOYMENT.md.
TLS_CERT_PATH=
TLS_KEY_PATH=
